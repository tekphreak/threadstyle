<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000"
    android:gravity="center_horizontal"
    android:padding="24dp">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#000000"
        android:title="About"
        android:titleTextColor="#FFFFFFFF" />

    <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

    <ImageView
        android:id="@+id/appIcon"
        android:layout_width="96dp"
        android:layout_height="96dp"
        android:src="@mipmap/ic_launcher"
        android:contentDescription="ThreadStyle icon" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:text="ThreadStyle"
        android:textColor="#FFFFFFFF"
        android:textSize="24sp"
        android:textStyle="bold|italic" />

    <TextView
        android:id="@+id/versionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="6dp"
        android:textColor="#80FFFFFF"
        android:textSize="14sp" />

    <Space android:layout_width="0dp" android:layout_height="0dp" android:layout_weight="1" />

    <Button
        android:id="@+id/websiteButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="12dp"
        android:text="tekphreak.com"
        android:textColor="#FFFFFFFF"
        android:backgroundTint="#000000"
        app:strokeColor="#00b140"
        app:strokeWidth="1dp"
        style="?attr/materialButtonStyle" />

    <Button
        android:id="@+id/donateButton"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginBottom="24dp"
        android:text="Donate via Ko-fi"
        android:textColor="#FFFFFFFF"
        android:backgroundTint="#000000"
        app:strokeColor="#00b140"
        app:strokeWidth="1dp"
        style="?attr/materialButtonStyle" />

</LinearLayout>
