<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/black">

    <!-- Top bar card -->
    <androidx.cardview.widget.CardView
        android:id="@+id/topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_margin="12dp"
        app:cardBackgroundColor="@color/black"
        app:cardCornerRadius="12dp"
        app:cardElevation="0dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:padding="8dp"
            android:gravity="center_vertical">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="TextStyle"
                android:textColor="@color/white"
                android:textSize="18sp"
                android:textStyle="bold|italic" />

            <Button
                android:id="@+id/loadButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:layout_marginEnd="8dp"
                android:text="@string/load"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:backgroundTint="#000000"
                app:strokeColor="#00b140"
                app:strokeWidth="1dp"
                style="?attr/materialButtonStyle" />

            <Button
                android:id="@+id/copyButton"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="@string/copy"
                android:textColor="@color/white"
                android:textSize="12sp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:backgroundTint="#000000"
                app:strokeColor="#00b140"
                app:strokeWidth="1dp"
                style="?attr/materialButtonStyle" />

            <ImageButton
                android:id="@+id/settingsButton"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:layout_marginStart="8dp"
                android:src="@drawable/ic_settings"
                android:background="?attr/selectableItemBackgroundBorderless"
                android:contentDescription="Settings"
                android:tint="@color/white" />
        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Input section: main input + symbols panel + overflow -->
    <LinearLayout
        android:id="@+id/inputSection"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/topBar">

        <!-- Main input area -->
        <FrameLayout
            android:id="@+id/inputContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">

            <com.tekphreak.threadstyle.StylerEditText
                android:id="@+id/composerInput"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/input_bg"
                android:textColor="@color/white"
                android:textColorHint="@color/white_50"
                android:hint="@string/composer_hint"
                android:padding="12dp"
                android:paddingBottom="28dp"
                android:minLines="6"
                android:maxLines="10"
                android:inputType="textMultiLine|textCapSentences"
                android:gravity="top|start"
                android:textSize="16sp"
                android:scrollbars="vertical" />

            <TextView
                android:id="@+id/charCounter"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="bottom|end"
                android:layout_margin="6dp"
                android:text="0 / 500"
                android:textColor="@color/white_50"
                android:textSize="11sp" />
        </FrameLayout>

        <!-- Symbols toggle button -->
        <Button
            android:id="@+id/symbolsToggle"
            android:layout_width="wrap_content"
            android:layout_height="32dp"
            android:layout_marginTop="4dp"
            android:text="★ Symbols"
            android:textColor="@color/white"
            android:textSize="11sp"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:backgroundTint="#000000"
            app:strokeColor="#00b140"
            app:strokeWidth="1dp"
            style="?attr/materialButtonStyle" />

        <!-- Symbols panel (hidden by default) -->
        <HorizontalScrollView
            android:id="@+id/symbolsPanel"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="4dp"
            android:visibility="gone"
            android:scrollbars="none">

            <LinearLayout
                android:id="@+id/symbolsContainer"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="2dp" />
        </HorizontalScrollView>

        <!-- Overflow Part 2 (hidden until text > 500 chars) -->
        <LinearLayout
            android:id="@+id/overflow2Container"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="8dp"
            android:visibility="gone">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Part 2"
                    android:textColor="#FFFFFFFF"
                    android:textSize="12sp"
                    android:textStyle="bold" />

                <Button
                    android:id="@+id/copyButton2"
                    android:layout_width="wrap_content"
                    android:layout_height="32dp"
                    android:text="⬇ Copy Part 2"
                    android:textColor="@color/white"
                    android:textSize="11sp"
                    android:paddingStart="12dp"
                    android:paddingEnd="12dp"
                    android:backgroundTint="#000000"
                    app:strokeColor="#00b140"
                    app:strokeWidth="1dp"
                    style="?attr/materialButtonStyle" />
            </LinearLayout>

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="4dp">

                <EditText
                    android:id="@+id/overflow2Input"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:background="@drawable/input_bg"
                    android:textColor="@color/white"
                    android:padding="12dp"
                    android:paddingBottom="28dp"
                    android:minLines="3"
                    android:maxLines="6"
                    android:inputType="textMultiLine"
                    android:gravity="top|start"
                    android:textSize="16sp"
                    android:scrollbars="vertical"
                    android:focusable="false"
                    android:clickable="false" />

                <TextView
                    android:id="@+id/charCounter2"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_gravity="bottom|end"
                    android:layout_margin="6dp"
                    android:text="0"
                    android:textColor="@color/white_50"
                    android:textSize="11sp" />
            </FrameLayout>
        </LinearLayout>

    </LinearLayout>

    <!-- Style buttons scroll area -->
    <ScrollView
        android:id="@+id/scrollView"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="8dp"
        app:layout_constraintBottom_toTopOf="@id/hintText"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/inputSection">

        <GridLayout
            android:id="@+id/styleButtonGrid"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:columnCount="4"
            android:padding="8dp"
            android:useDefaultMargins="false" />
    </ScrollView>

    <!-- Hint text -->
    <TextView
        android:id="@+id/hintText"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginBottom="8dp"
        android:text="@string/hint_text"
        android:textColor="@color/white_50"
        android:textSize="11sp"
        android:textStyle="italic"
        android:gravity="center"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
