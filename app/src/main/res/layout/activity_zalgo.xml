<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#000000">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="?attr/actionBarSize"
        android:background="#000000"
        android:title="Zalgo"
        android:titleTextColor="#FFFFFFFF" />

    <!-- Zalgo output -->
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="12dp"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="4dp">

        <EditText
            android:id="@+id/zalgoOutput"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:background="@drawable/input_bg"
            android:textColor="#FFFFFF"
            android:padding="12dp"
            android:paddingBottom="28dp"
            android:inputType="textMultiLine"
            android:gravity="top|start"
            android:textSize="15sp"
            android:scrollbars="vertical"
            android:focusable="false"
            android:clickable="false" />

        <TextView
            android:id="@+id/zalgoCharCounter"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="bottom|end"
            android:layout_margin="6dp"
            android:text="0 / 500"
            android:textColor="#80FFFFFF"
            android:textSize="11sp" />

    </FrameLayout>

    <!-- Bottom controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:paddingStart="16dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:paddingTop="4dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <TextView
                android:id="@+id/crazinessLabel"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Craziness: Normal"
                android:textColor="#FFFFFFFF"
                android:textSize="13sp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Mild"
                android:textColor="#80FFFFFF"
                android:textSize="11sp"
                android:layout_marginEnd="4dp" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="He comes"
                android:textColor="#80FFFFFF"
                android:textSize="11sp" />

        </LinearLayout>

        <SeekBar
            android:id="@+id/crazinessSlider"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:progress="50"
            android:progressTint="#00b140"
            android:thumbTint="#00b140"
            android:layout_marginBottom="12dp" />

        <Button
            android:id="@+id/copyZalgoButton"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⬇ Copy Zalgo"
            android:textColor="#FFFFFF"
            android:backgroundTint="#000000"
            app:strokeColor="#00b140"
            app:strokeWidth="1dp"
            style="?attr/materialButtonStyle" />

    </LinearLayout>

</LinearLayout>
